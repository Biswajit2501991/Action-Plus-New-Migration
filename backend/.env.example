NODE_ENV=development
PORT=4000
JWT_SECRET=change-me
JWT_EXPIRES_IN=2h
# V-002 Phase 2B–2D: store JWT in HttpOnly cookie instead of localStorage (default off)
# APG_AUTH_COOKIE_MODE=1
DATABASE_PATH=./data/app.db
DATA_BACKEND=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APG_GYM_ID=your-gym-uuid
# Same secret as Gym Website MEMBER_PORTAL_JWT_SECRET — required to verify member digital QR (APG1.)
MEMBER_PORTAL_JWT_SECRET=
# How many months of payment_history to include on GET /members?view=list (Finance ledger). Default 84.
# APG_PAYMENT_HISTORY_LIST_MONTHS_BACK=84
# After deploy: staff must sign in again so JWT includes gymId.
# Set to true in production once all sessions are refreshed:
# APG_ENFORCE_GYM_JWT=true

# CORS: comma-separated browser origins allowed to call the API
# Production default (if unset): https://app.gymactionplus.com
# Development default (if unset): app URL + http://127.0.0.1:5501 and :5500
CORS_ALLOWED_ORIGINS=https://app.gymactionplus.com,http://127.0.0.1:5501,http://127.0.0.1:5500

# Login brute-force protection (per client IP, failed attempts only)
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000

# Process control (Backend tab restart/stop). Prefer false when API is on the public internet.
PROCESS_CONTROL_ENABLED=false
# Process control (local dev only — must be false in production)
# PROCESS_CONTROL_ENABLED=false
# PROCESS_CONTROL_TOKEN=long-random-string-if-enabled-locally
# APG_SUPERVISOR_TOKEN=same-as-process-control-for-supervisor-proxy

# Database password for SQL setup scripts (NOT the service_role API key)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_REGION=ap-south-1

# Multi-branch staff assignments + branch switcher (recommended production)
BRANCH_OWNER_ENABLED=true

# --- Production (copy to backend/.env on server) ---
# NODE_ENV=production
# PROCESS_CONTROL_ENABLED=false
# Rotate keys: npm run security:rotate-guide
