NODE_ENV=development
PORT=4000
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
DATABASE_PATH=./data/app.db
DATA_BACKEND=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APG_GYM_ID=your-gym-uuid
# Database password for SQL setup scripts (NOT the service_role API key)
# Option A — full URI from Supabase → Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Option B — password only (special characters OK); set region if not ap-south-1
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_REGION=ap-south-1
