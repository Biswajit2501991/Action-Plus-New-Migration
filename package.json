{
  "name": "action-plus-gym-manager",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:local": "ENV_FILE=.env.local npm run dev:all:isolated",
    "start:local:tunnel": "ENV_FILE=.env.local node scripts/dev-all-isolated-with-tunnel.mjs",
    "start:prod": "ENV_FILE=.env.prod npm run prod:start",
    "prod:start": "node scripts/bootstrap-and-run.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:all:isolated": "node scripts/dev-all-isolated.mjs",
    "dev:web": "node scripts/dev-frontend.mjs",
    "dev:tunnel": "node scripts/cloudflare-tunnel.mjs",
    "dev:all:tunnel": "node scripts/dev-all-with-tunnel.mjs",
    "build:legacy:prod": "node scripts/build-legacy-prod-frontend.mjs",
    "prod:health": "zsh scripts/health-check-after-boot.sh",
    "prod:verify-api": "node scripts/verify-prod-api.mjs",
    "local:health": "zsh scripts/health-check-after-boot.sh http://127.0.0.1:5501/index.html http://127.0.0.1:5501/index.html",
    "local:test": "npm test && npm run local:health",
    "health:check": "zsh scripts/health-check-after-boot.sh",
    "watchdog:start": "zsh scripts/watchdog-autorestart.sh",
    "autostart:install": "zsh scripts/install-autostart-macos.sh",
    "autostart:uninstall": "zsh scripts/uninstall-autostart-macos.sh",
    "dev:supervisor": "node scripts/apg-supervisor.mjs",
    "icon:refresh": "zsh scripts/refresh-icon-cache.sh",
    "backfill:payments:dry": "node backend/scripts/backfill-member-payment-history.js --dry-run",
    "backfill:payments": "node backend/scripts/backfill-member-payment-history.js",
    "backfill:paid-month:dry": "node backend/scripts/backfill-paid-month.js --dry-run",
    "backfill:paid-month": "node backend/scripts/backfill-paid-month.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "install:v2": "npm install --prefix v2",
    "build:v2": "npm run build:strangler --prefix v2",
    "dev:v2": "npm run dev --prefix v2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1",
    "vitest": "^2.1.9"
  }
}
