# Frontend dev server settings
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5500

# Backend settings used by frontend defaults
BACKEND_PORT=4000
API_BASE_URL=/api

# Cloudflare Tunnel (optional)
# If CF_TUNNEL_TOKEN is set, named tunnel mode is used.
# If empty, `npm run dev:tunnel` creates a temporary trycloudflare URL.
CF_TUNNEL_TOKEN=
# Override local origin exposed via tunnel if needed
CF_TUNNEL_URL=http://127.0.0.1:5500

# macOS: set to 1 so scripts/run-autostart.sh and the .app launcher (bootstrap-and-run.mjs)
# wrap the stack in `caffeinate -dims`, deferring idle/display/disk sleep while the tunnel runs.
# Set to 1 on macOS production Mac to keep tunnel alive (see README autostart section)
APG_CAFFEINATE=
