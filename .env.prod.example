# Production-origin endpoints (Cloudflare routed app)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5501
BACKEND_PORT=4000
API_BASE_URL=/api

# Named Cloudflare tunnel token for production route
CF_TUNNEL_TOKEN=
CF_TUNNEL_URL=http://127.0.0.1:5501

# Optional macOS sleep protection for long-running production session
APG_CAFFEINATE=1

# React Visitors UI at https://app.gymactionplus.com/v2/visitors (build: npm run build:v2)
V2_VISITORS_ENABLED=1

# Backend security (also set in backend/.env — backend loads backend/.env on start)
# NODE_ENV=production
# CORS_ALLOWED_ORIGINS=https://app.gymactionplus.com
# PROCESS_CONTROL_ENABLED=false
# JWT_SECRET=<run: cd backend && npm run security:new-jwt-secret>
# SUPABASE_SERVICE_ROLE_KEY=<regenerate in Supabase dashboard → API → service_role>
