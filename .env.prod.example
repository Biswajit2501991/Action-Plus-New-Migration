# Production-origin endpoints (Cloudflare routed app)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5501
BACKEND_PORT=4000
API_BASE_URL=/api

# Named Cloudflare tunnel token for production route
CF_TUNNEL_TOKEN=
CF_TUNNEL_URL=http://127.0.0.1:5501

# Optional macOS sleep protection for long-running production session
APG_CAFFEINATE=1
