# Production-origin endpoints (Cloudflare routed app)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5501
BACKEND_PORT=4000
API_BASE_URL=/api

# Named Cloudflare tunnel token for production route
CF_TUNNEL_TOKEN=
CF_TUNNEL_URL=http://127.0.0.1:5501

# Optional macOS sleep protection for long-running production session
APG_CAFFEINATE=1

# Legacy Visitors UI under Members → Visitors (set to 1 when v2 build is production-ready)
# V2_VISITORS_ENABLED=1
V2_VISITORS_ENABLED=0

# Backend security (also set in backend/.env — backend loads backend/.env on start)
# NODE_ENV=production
# CORS_ALLOWED_ORIGINS=https://app.gymactionplus.com
# PROCESS_CONTROL_ENABLED=false
# PROCESS_CONTROL_TOKEN=<local only — used by supervisor; never exposed to browser>
# APG_SUPERVISOR_TOKEN=<optional; same as PROCESS_CONTROL_TOKEN for supervisor proxy>
# APG_SUPERVISOR_PROXY_REQUIRE_OWNER=1
# JWT_SECRET=<required in production, min 32 chars — run: cd backend && npm run security:new-jwt-secret>
# JWT_EXPIRES_IN=2h
# APG_AUTH_SESSION_IDLE_MS=90m
# V-002 Phase 2B–2D: HttpOnly JWT cookie (off by default until staged rollout)
# APG_AUTH_COOKIE_MODE=1
# SUPABASE_SERVICE_ROLE_KEY=<regenerate in Supabase dashboard → API → service_role>
